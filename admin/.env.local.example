# Copy this file to .env.local and fill in your values

# Supabase — same project as the mobile app
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key for admin reads (never expose to browser — server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin password — set a strong secret; stored only in env
ADMIN_PASSWORD=change-me-to-something-strong
