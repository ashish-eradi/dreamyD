# ──────────────────────────────────────────────────────────────────────────────
# DreamDiary — Environment Variables
#
# Copy this file to .env and fill in your real values.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the client and visible
# to end users. DO NOT put secrets in EXPO_PUBLIC_ variables.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — project URL (safe to expose, protected by RLS)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url

# Supabase — anon / public key (safe to expose, protected by RLS)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI — SECRET: used server-side / via secure proxy, never bundle directly
# If calling OpenAI from the device during development, set here; for production
# route all AI calls through a Supabase Edge Function so this key stays hidden.
OPENAI_API_KEY=your_openai_api_key

# RevenueCat — platform-specific public SDK keys (safe to expose)
REVENUECAT_API_KEY_IOS=your_revenuecat_ios_key
REVENUECAT_API_KEY_ANDROID=your_revenuecat_android_key
